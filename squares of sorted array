class Solution {
public:
    vector<int> sortedSquares(vector<int>& nums) {
        int n=nums.size();
       vector<int> v(n);
       int low=0,high=n-1,ind=n-1;
       while(low<=high){
        if(abs(nums[low])>abs(nums[high])){
            v[ind]=nums[low]*nums[low];
            low++;
        }
        else{
            v[ind]=nums[high]*nums[high];
            high--;
        }
        ind--;
       }
       return v;
    }
};
