class Solution {
public:
    int pivotIndex(vector<int>& nums) {
        int left=0,total=0;
        for (auto i:nums){
            total+=i;
        }

        for(int i=0;i<nums.size();i++){
            int right=total-nums[i]-left;
            if(left==right) return i;
            left+=nums[i];
        }
        return -1;
    }
};
