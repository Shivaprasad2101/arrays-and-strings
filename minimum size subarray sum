class Solution {
public:
    int minSubArrayLen(int target, vector<int>& nums) {
        int i=0,j=0;
        int sum=0,le=INT_MAX;
        while(j<nums.size()){
            sum+=nums[j];
            while(sum>=target){
                le=min(j-i+1,le);
                sum-=nums[i++];
            }
            j++;
        }
        return (le==INT_MAX)?0:le;
    }
};
